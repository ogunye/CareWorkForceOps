@{
    ViewData["Title"] = "CareWorkOps";
    Layout = "_LandingLayout";
}

<section class="hero">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6">

                <span class="badge bg-primary mb-3">
                    Compliance First Care Platform
                </span>

                <h1 class="hero-title">
                    Smarter Care Operations
                </h1>

                <p class="hero-text mt-4">
                    Manage service users,
                    staff, compliance,
                    care plans, incidents
                    and scheduling from
                    one intelligent platform.
                </p>

                <div class="mt-4">

                    <a asp-controller="Account"
                       asp-action="Login"
                       class="btn btn-primary btn-lg">
                        Sign In
                    </a>

                    <a href="#features"
                       class="btn btn-outline-secondary btn-lg">
                        Learn More
                    </a>

                </div>

            </div>

            <div class="col-lg-6 text-center">

                <img src="~/images/dashboard-preview.png"
                     class="img-fluid"
                     alt="Dashboard Preview" />

            </div>

        </div>

    </div>

</section>